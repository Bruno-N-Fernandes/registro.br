{
  "manifest_version": 3,
  "name": "Registro.br DNS Helper",
  "version": "1.0.0",
  "description": "Cria e configura registros DNS e subdomínios no painel do registro.br de forma automatizada, usando a sua própria sessão autenticada.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "*://registro.br/*",
    "*://*.registro.br/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Registro.br DNS Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://registro.br/*", "*://*.registro.br/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
